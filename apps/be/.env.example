# =====================
# 공통 설정
# =====================

# 실행 환경: development | production
NODE_ENV=development

# 타임존 (한국 시간 기준)
TZ=Asia/Seoul

# 서버 포트
PORT=4000

# 앱인토스 앱 이름 (CORS 설정용, 콘솔 등록명과 동일하게)
APP_NAME=gdp-worldcup

# 운영 서버 외부 IP (FE config.ts에서 참조, BE는 직접 사용 안 함)
# SERVER_IP=34.173.234.88

# 공공 데이터 API 키 (data.go.kr 발급)
PUBLIC_DATA_API_KEY=YOUR_API_KEY_HERE

# 공공 데이터 API Base URL
PUBLIC_DATA_API_BASE_URL=http://apis.data.go.kr/1262000/OverviewEconomicService/OverviewEconomicList

# 국가 캐시 TTL (초, 기본 7일)
COUNTRY_CACHE_TTL_SECONDS=604800

# =====================
# DB 설정 (환경에 따라 선택)
# =====================

DATABASE_URL="postgresql://gdpuser:PASSWORD@localhost:5432/gdpworldcup"

# =====================
# 앱인토스 mTLS / 토스 로그인
# =====================

# mTLS 인증서 경로
AIT_MTLS_CERT_PATH=/path/to/gdp-quiz-login_public.crt
AIT_MTLS_KEY_PATH=/path/to/gdp-quiz-login_private.key

# 토스 로그인 복호화 키
AIT_DECRYPT_KEY=YOUR_DECRYPT_KEY_HERE
AIT_DECRYPT_AAD=TOSS

# 회원 탈퇴(unlink) 콜백 Basic Auth 시크릿
AIT_UNLINK_SECRET=YOUR_UNLINK_SECRET_HERE

# =====================
# 앱인토스 프로모션 (토스 포인트 지급)
# =====================

# 콘솔에서 발급받은 프로모션 코드
AIT_PROMOTION_CODE=YOUR_PROMOTION_CODE_HERE

# 1회 지급 포인트 (원)
AIT_PROMOTION_AMOUNT=1
