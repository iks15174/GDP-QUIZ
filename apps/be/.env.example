# =====================
# 공통 설정
# =====================

# 실행 환경: development | production
NODE_ENV=development

# 서버 포트
PORT=4000

# 앱인토스 앱 이름 (CORS 설정용, 콘솔 등록명과 동일하게)
APP_NAME=gdp-worldcup

# 운영 서버 외부 IP (FE config.ts에서 참조, BE는 직접 사용 안 함)
# SERVER_IP=34.173.234.88

# 공공 데이터 API 키 (data.go.kr 발급)
PUBLIC_DATA_API_KEY=YOUR_API_KEY_HERE

# 공공 데이터 API Base URL
PUBLIC_DATA_API_BASE_URL=http://apis.data.go.kr/1262000/OverviewEconomicService/OverviewEconomicList

# 국가 캐시 TTL (초, 기본 7일)
COUNTRY_CACHE_TTL_SECONDS=604800

# =====================
# DB 설정 (환경에 따라 선택)
# =====================

# 로컬 (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# 운영 (PostgreSQL) — 운영 서버 .env에서 아래로 교체
# DATABASE_URL="postgresql://gdpuser:PASSWORD@localhost:5432/gdpworldcup"
